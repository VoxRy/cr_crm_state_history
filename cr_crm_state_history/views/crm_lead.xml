<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_cr_crm_lead_form" model="ir.ui.view">
        <field name="name">cr.crm.lead.form</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
             <xpath expr="//page[@name='lead']" position='after'>
                <page string="Stage Change History" groups="cr_crm_state_history.cr_group_access">
                    <field name="cr_crm_stage_change_history_ids">
                        <tree editable="bottom">
                            <field name="stage_name"/>
                            <field name="date_in"/>
                            <field name="date_in_by_id"/>
                            <field name="date_out"/>
                            <field name="date_out_by_id"/>
                            <field name="day_diff"/>
                            <field name="time_diff"/>
                            <field name="total_time_diff"/>
                        </tree>
                    </field>
                </page>
	         </xpath>
        </field>
    </record>
</odoo>