<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_cr_stage_change_history_search" model="ir.ui.view">
        <field name="name">cr.stage.change.history.search</field>
        <field name="model">cr.crm.stage.change.history</field>
        <field name="arch" type="xml">
          <search>
            <group expand="0" string="Group By">
                <filter string="Stage Task" name="crm_lead_id" context="{'group_by': 'crm_lead_id'}"/>
                <filter string="Stage Name" name="stage_name" context="{'group_by': 'stage_name'}"/>
            </group>
          </search>
       </field>
    </record>

    <record id="view_cr_stage_change_history_tree" model="ir.ui.view">
        <field name="name">cr.stage.change.history.tree</field>
        <field name="model">cr.crm.stage.change.history</field>
        <field name="arch" type="xml">
            <tree string="Stage Change History">
                <field name="crm_lead_id"/>
                <field name="stage_name"/>
                <field name="date_in"/>
                <field name="date_in_by_id"/>
                <field name="date_out"/>
                <field name="date_out_by_id"/>
                <field name="day_diff"/>
                <field name="time_diff"/>
                <field name="total_time_diff"/>
            </tree>
        </field>
    </record>

    <record id="view_cr_stage_change_history_pivot" model="ir.ui.view">
       <field name="name">cr.stage.change.history.pivot</field>
       <field name="model">cr.crm.stage.change.history</field>
       <field name="arch" type="xml">
           <pivot string="Stage Change History">
               <field name="crm_lead_id" type="row"/>
                <field name="day_diff" type="measure"/>
                <field name="time_diff" type="measure"/>
                <field name="total_time_diff" type="measure"/>
           </pivot>
       </field>
    </record>
</odoo>
